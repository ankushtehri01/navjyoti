# ============================================================
#  Nav Jyoti — Backend Environment Variables
#  Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================

# ---------- App ----------
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:5173

# ---------- Database ----------
MONGO_URI=mongodb://127.0.0.1:27017/navjyoti

# ---------- JWT ----------
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_REFRESH_EXPIRY=7d
JWT_RESET_SECRET=replace_with_a_long_random_reset_secret
JWT_RESET_EXPIRY=15m

# ---------- Cookies ----------
COOKIE_SECRET=replace_with_a_long_random_cookie_secret

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=navjyoti

# ---------- Mail (Nodemailer / SMTP) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=Nav Jyoti
MAIL_FROM_ADDRESS=no-reply@navjyoti.com

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ---------- Uploads ----------
MAX_FILE_SIZE_MB=5

# ---------- Seed (optional bootstrap admin) ----------
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@navjyoti.com
SEED_ADMIN_PASSWORD=Admin@12345
