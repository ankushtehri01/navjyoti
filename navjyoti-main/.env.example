# ============================================================
#  Nav Jyoti — docker-compose secrets
#  Copy to `.env`. Generate secrets with:  openssl rand -hex 32
# ============================================================

# Public URL the browser hits (used for CORS + reset links)
CLIENT_URL=http://localhost
WEB_PORT=80

# ---------- JWT / cookies (REQUIRED — use long random values) ----------
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_RESET_SECRET=change_me_reset_secret
COOKIE_SECRET=change_me_cookie_secret

# Cookie flags. Over plain HTTP (local compose) keep these as below.
# Behind real HTTPS, set COOKIE_SECURE=true and COOKIE_SAMESITE=none.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ---------- Cloudinary (optional — uploads fall back to stubs if unset) ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- SMTP (optional — emails are logged if unset) ----------
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# ---------- Seed admin ----------
SEED_ADMIN_EMAIL=admin@navjyoti.com
SEED_ADMIN_PASSWORD=Admin@12345
